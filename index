  <script>
    // 正确的账号和密码
    const CORRECT_USERNAME = "1277142820";
    const CORRECT_PASSWORD = "kfcvme50";

    // 登录状态
    let isLoggedIn = false;
    let loggedUsername = "";

    // 点赞计数
    let likeCounts = {
      fasting: 128,
      preaching: 128,
      witness: 234,
      meditation: 23
    };

    // 分享计数
    let shareCounts = {
      fasting: 66,
      preaching: 66,
      witness: 89,
      meditation: 5
    };

    // 报名计数
    let signupCount = 123;

    // 当前报名者姓名
    let currentSignupName = "";

    // 获取元素
    const container = document.getElementById('mainContainer');
    const outerContent = document.getElementById('outerContent');
    const innerContent = document.getElementById('innerContent');
    const loginModal = document.getElementById('loginModal');
    const loginStatus = document.getElementById('loginStatus');
    const loggedUserSpan = document.getElementById('loggedUser');
    const surveyModal = document.getElementById('surveyModal');
    const wechatToast = document.getElementById('wechatToast');
    const toastMessage = document.getElementById('toastMessage');

    // ========== 登录相关函数 ==========
    function initLoginState() {
      const savedLogin = localStorage.getItem('baihua_logged_in');
      if (savedLogin === 'true') {
        const savedUsername = localStorage.getItem('baihua_username');
        if (savedUsername === CORRECT_USERNAME) {
          isLoggedIn = true;
          loggedUsername = savedUsername;
          updateLoginStatus();
        } else {
          logout();
        }
      }
    }

    function updateLoginStatus() {
      if (isLoggedIn) {
        loggedUserSpan.textContent = loggedUsername;
        loginStatus.style.display = 'flex';
      } else {
        loginStatus.style.display = 'none';
      }
    }

    function saveLoginState() {
      localStorage.setItem('baihua_logged_in', 'true');
      localStorage.setItem('baihua_username', loggedUsername);
    }

    function clearLoginState() {
      localStorage.removeItem('baihua_logged_in');
      localStorage.removeItem('baihua_username');
    }

    function showLoginModal() {
      loginModal.style.display = 'flex';
      document.getElementById('loginUsername').value = '';
      document.getElementById('loginPassword').value = '';
    }

    function hideLoginModal() {
      loginModal.style.display = 'none';
    }

    function handleLogin() {
      const username = document.getElementById('loginUsername').value.trim();
      const password = document.getElementById('loginPassword').value;
      
      if (username === '') {
        alert("请输入账号");
        return;
      }
      if (password === '') {
        alert("请输入密码");
        return;
      }
      
      if (username !== CORRECT_USERNAME) {
        alert("当前账号不存在");
        return;
      }
      
      if (password !== CORRECT_PASSWORD) {
        alert("密码错误");
        return;
      }
      
      isLoggedIn = true;
      loggedUsername = username;
      saveLoginState();
      updateLoginStatus();
      
      hideLoginModal();
      showInnerContent();
    }

    function logout() {
      isLoggedIn = false;
      loggedUsername = "";
      clearLoginState();
      updateLoginStatus();
      
      if (innerContent.style.display === 'block') {
        showOuterContent();
      }
    }

    // ========== 页面切换函数 ==========
    function showInnerContent() {
      outerContent.style.display = 'none';
      innerContent.style.display = 'block';
      container.parentElement.classList.add('inner-shrine');
    }

    function showOuterContent() {
      outerContent.style.display = 'block';
      innerContent.style.display = 'none';
      container.parentElement.classList.remove('inner-shrine');
    }

    function handleEnterInner() {
      if (isLoggedIn) {
        showInnerContent();
      } else {
        showLoginModal();
      }
    }

    // ========== 展开/折叠函数 ==========
    function toggleExpand(id) {
      const element = document.getElementById(id);
      const btn = event.currentTarget;
      if (element.style.display === 'none' || element.style.display === '') {
        element.style.display = 'block';
        btn.textContent = '▲ 收起详细介绍';
      } else {
        element.style.display = 'none';
        btn.textContent = '▼ 展开查看详细介绍';
      }
    }

    // ========== 点赞函数 ==========
    function likePost(btn, postId) {
      likeCounts[postId]++;
      const span = btn.querySelector('span');
      if (span) {
        span.textContent = likeCounts[postId];
      }
      btn.classList.add('liked');
      setTimeout(() => {
        btn.classList.remove('liked');
      }, 200);
    }

    // ========== 分享函数 ==========
    function sharePost(btn, postId) {
      shareCounts[postId]++;
      const span = btn.querySelector('span');
      if (span) {
        span.textContent = shareCounts[postId];
      }
      alert('分享成功！功德 +1');
    }

    // ========== 问卷相关函数 ==========
    function showSurveyModal() {
      surveyModal.style.display = 'flex';
    }

    function hideSurveyModal() {
      surveyModal.style.display = 'none';
    }

    function showToast(name) {
      toastMessage.innerHTML = `<strong>${name}</strong> 申请加你为好友`;
      wechatToast.style.display = 'flex';
      
      // 5秒后自动隐藏
      setTimeout(() => {
        if (wechatToast.style.display === 'flex') {
          wechatToast.style.display = 'none';
        }
      }, 5000);
    }

    function hideToast() {
      wechatToast.style.display = 'none';
    }

   function openNewPage() {
  window.open('微信页面.html', '_blank');
  hideToast();
}

    function submitSurvey() {
      const name = document.getElementById('surveyName').value;
      const age = document.getElementById('surveyAge').value;
      const gender = document.getElementById('surveyGender').value;
      const id = document.getElementById('surveyId').value;
      const phone = document.getElementById('surveyPhone').value;

      if (!name || !age || !gender || !id || !phone) {
        alert("请填写所有必填项");
        return;
      }

      // 报名计数增加
      signupCount++;
      const signupSpan = document.getElementById('fastingSignupCount');
      if (signupSpan) {
        signupSpan.textContent = signupCount;
      }

      // 保存当前报名者姓名
      currentSignupName = name;

      // 显示微信风格提示
      showToast(name);

      hideSurveyModal();
      
      // 清空表单
      document.getElementById('surveyName').value = '';
      document.getElementById('surveyAge').value = '';
      document.getElementById('surveyGender').value = '';
      document.getElementById('surveyId').value = '';
      document.getElementById('surveyPhone').value = '';
    }

    // 点击模态框外部关闭
    window.onclick = function(event) {
      if (event.target === loginModal) {
        hideLoginModal();
      }
      if (event.target === surveyModal) {
        hideSurveyModal();
      }
    }

    // 初始化
    initLoginState();

    // 将函数暴露给全局
    window.showLoginModal = showLoginModal;
    window.hideLoginModal = hideLoginModal;
    window.handleLogin = handleLogin;
    window.showOuterContent = showOuterContent;
    window.handleEnterInner = handleEnterInner;
    window.logout = logout;
    window.toggleExpand = toggleExpand;
    window.likePost = likePost;
    window.sharePost = sharePost;
    window.showSurveyModal = showSurveyModal;
    window.hideSurveyModal = hideSurveyModal;
    window.submitSurvey = submitSurvey;
    window.hideToast = hideToast;
    window.openNewPage = openNewPage;
  </script>
