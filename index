  </div>

  <!-- 问卷模态框（初始隐藏） -->
  <div id="surveyModal" class="survey-modal" style="display: none;">
    <div class="survey-box">
      <h3>🌸 七日断食报名表</h3>
      <label>姓名：</label>
      <input type="text" id="surveyName" placeholder="请输入真实姓名">
      
      <label>年龄：</label>
